# ── Required ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-32-plus-byte-random-secret
TOKEN_EXPIRY_HOURS=72

# ── Security ──
# Set to false in production to disable the X-User-Id header bypass
DEV_AUTH=false
# Comma-separated list of allowed origins (your deployed domain)
ALLOWED_ORIGINS=https://yourdomain.com

# ── Billing (optional — Stripe) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── Storage ──
# Defaults to ./data if not set
# VOICE_DATA_DIR=/var/data/voice

# ── Rate limiting ──
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=300
